{
	"manifest_version": 3,
	"name": "Review Rank",
	"version": "0.1.2",
	"description": "Force Prime-only Amazon search results, sort by review rank, block sponsored posts, hide low-review products, and optionally apply a brand allowlist.",
	"permissions": ["storage", "alarms", "webNavigation"],
	"host_permissions": [
		"https://raw.githubusercontent.com/chris-mosley/AmazonBrandFilterList/*"
	],
	"browser_specific_settings": {
		"gecko": {
			"id": "prime-rank-filter@primerank.dev",
			"strict_min_version": "140.0",
			"data_collection_permissions": {
				"required": ["none"],
				"optional": []
			}
		}
	},
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'none'"
	},
	"background": {
		"service_worker": "background.js",
		"scripts": [
			"prime-rank-shared.js",
			"amazon-brand-whitelist.js",
			"background.js"
		]
	},
	"action": {
		"default_title": "Review Rank",
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon-16.png",
			"48": "icons/icon-48.png",
			"96": "icons/icon-96.png"
		}
	},
	"icons": {
		"16": "icons/icon-16.png",
		"48": "icons/icon-48.png",
		"96": "icons/icon-96.png"
	},
	"content_scripts": [
		{
			"matches": [
				"*://*.amazon.com/*",
				"*://*.amazon.ca/*",
				"*://*.amazon.cn/*",
				"*://*.amazon.co.uk/*",
				"*://*.amazon.co.za/*",
				"*://*.amazon.de/*",
				"*://*.amazon.fr/*",
				"*://*.amazon.it/*",
				"*://*.amazon.es/*",
				"*://*.amazon.nl/*",
				"*://*.amazon.se/*",
				"*://*.amazon.pl/*",
				"*://*.amazon.com.au/*",
				"*://*.amazon.com.br/*",
				"*://*.amazon.com.mx/*",
				"*://*.amazon.co.jp/*",
				"*://*.amazon.in/*",
				"*://*.amazon.sg/*",
				"*://*.amazon.ae/*",
				"*://*.amazon.sa/*",
				"*://*.amazon.com.tr/*",
				"*://*.amazon.eg/*",
				"*://*.amazon.com.be/*"
			],
			"js": ["prime-rank-shared.js", "content-script.js"],
			"run_at": "document_idle"
		}
	]
}
